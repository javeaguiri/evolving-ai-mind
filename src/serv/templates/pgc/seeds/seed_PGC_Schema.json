[
  {
    "table_name": "PGC_Schema",
    "target": "pgc",
    "description": "Registry of all table definitions — system bootstrap and user domain schemas. Self-describing.",
    "columns": [
      { "name": "id",           "type": "serial",      "primaryKey": true },
      { "name": "table_name",   "type": "text",        "nullable": false, "unique": true },
      { "name": "target",       "type": "text",        "nullable": false },
      { "name": "description",  "type": "text",        "nullable": true },
      { "name": "columns",      "type": "jsonb",       "nullable": false },
      { "name": "foreign_keys", "type": "jsonb",       "nullable": true,  "default": "'[]'::jsonb" },
      { "name": "constraints",  "type": "jsonb",       "nullable": true,  "default": "'[]'::jsonb" },
      { "name": "triggers",     "type": "jsonb",       "nullable": true,  "default": "'[]'::jsonb" },
      { "name": "created_at",   "type": "timestamptz", "nullable": false, "default": "now()" },
      { "name": "updated_at",   "type": "timestamptz", "nullable": false, "default": "now()" }
    ],
    "foreign_keys": [],
    "constraints": [
      { "type": "check", "name": "chk_target", "expression": "target IN ('pgc', 'pgd')" }
    ],
    "triggers": [
      { "name": "trg_pgc_schema_updated_at", "timing": "BEFORE UPDATE", "function": "set_updated_at()" }
    ]
  },
  {
    "table_name": "PGC_TableMap",
    "target": "pgc",
    "description": "Registry of all active tables that SERV-Table is permitted to write to. Security gatekeeper.",
    "columns": [
      { "name": "id",           "type": "serial",      "primaryKey": true },
      { "name": "table_name",   "type": "text",        "nullable": false, "unique": true },
      { "name": "target",       "type": "text",        "nullable": false },
      { "name": "schema_id",    "type": "integer",     "nullable": false },
      { "name": "allow_insert", "type": "boolean",     "nullable": false, "default": "true" },
      { "name": "allow_update", "type": "boolean",     "nullable": false, "default": "true" },
      { "name": "allow_delete", "type": "boolean",     "nullable": false, "default": "false" },
      { "name": "views",        "type": "jsonb",       "nullable": true,  "default": "'[]'::jsonb" },
      { "name": "created_at",   "type": "timestamptz", "nullable": false, "default": "now()" },
      { "name": "updated_at",   "type": "timestamptz", "nullable": false, "default": "now()" }
    ],
    "foreign_keys": [
      {
        "name": "fk_tablemap_schema",
        "column": "schema_id",
        "references": { "table": "PGC_Schema", "column": "id" },
        "onDelete": "RESTRICT"
      }
    ],
    "constraints": [
      { "type": "check", "name": "chk_target", "expression": "target IN ('pgc', 'pgd')" }
    ],
    "triggers": [
      { "name": "trg_pgc_tablemap_updated_at", "timing": "BEFORE UPDATE", "function": "set_updated_at()" }
    ]
  },
  {
    "table_name": "PGC_EntitySchema",
    "target": "pgc",
    "description": "Defines business entities spanning multiple PGD tables. SERV-Entity reads this to build jsonb_agg queries.",
    "columns": [
      { "name": "id",           "type": "serial",      "primaryKey": true },
      { "name": "entity_name",  "type": "text",        "nullable": false, "unique": true },
      { "name": "description",  "type": "text",        "nullable": true },
      { "name": "root_table",   "type": "text",        "nullable": false },
      { "name": "joins",        "type": "jsonb",       "nullable": false, "default": "'[]'::jsonb" },
      { "name": "aggregations", "type": "jsonb",       "nullable": false, "default": "'[]'::jsonb" },
      { "name": "filters",      "type": "jsonb",       "nullable": true,  "default": "'[]'::jsonb" },
      { "name": "created_at",   "type": "timestamptz", "nullable": false, "default": "now()" },
      { "name": "updated_at",   "type": "timestamptz", "nullable": false, "default": "now()" }
    ],
    "foreign_keys": [],
    "constraints": [],
    "triggers": [
      { "name": "trg_pgc_entityschema_updated_at", "timing": "BEFORE UPDATE", "function": "set_updated_at()" }
    ]
  },
  {
    "table_name": "PGC_DomainHelp",
    "target": "pgc",
    "description": "User-facing command aliases and help text per domain. Powers /help {domain} responses.",
    "columns": [
      { "name": "id",          "type": "serial",      "primaryKey": true },
      { "name": "domain",      "type": "text",        "nullable": false, "unique": true },
      { "name": "aliases",     "type": "jsonb",       "nullable": false, "default": "'[]'::jsonb" },
      { "name": "description", "type": "text",        "nullable": true },
      { "name": "commands",    "type": "jsonb",       "nullable": false, "default": "'[]'::jsonb" },
      { "name": "created_at",  "type": "timestamptz", "nullable": false, "default": "now()" },
      { "name": "updated_at",  "type": "timestamptz", "nullable": false, "default": "now()" }
    ],
    "foreign_keys": [],
    "constraints": [
      { "type": "unique", "name": "uq_domainhelp_domain", "columns": ["domain"] }
    ],
    "triggers": [
      { "name": "trg_pgc_domainhelp_updated_at", "timing": "BEFORE UPDATE", "function": "set_updated_at()" }
    ]
  },
  {
    "table_name": "PGC_Workflow",
    "target": "pgc",
    "description": "Stores reusable workflow definitions generated by LLM or created manually. Reused across runs — LLM is not called twice for the same workflow.",
    "columns": [
      { "name": "id",                       "type": "serial",      "primaryKey": true },
      { "name": "name",                     "type": "text",        "nullable": false, "unique": true },
      { "name": "description",              "type": "text",        "nullable": true },
      { "name": "intent_keywords",          "type": "jsonb",       "nullable": true,  "default": "'[]'::jsonb" },
      { "name": "intent_embedding",         "type": "vector",      "nullable": true },
      { "name": "steps",                    "type": "jsonb",       "nullable": false, "default": "'[]'::jsonb" },
      { "name": "state_strategy",           "type": "text",        "nullable": true },
      { "name": "confirmation_required_at", "type": "jsonb",       "nullable": true,  "default": "'[]'::jsonb" },
      { "name": "js_extensions",            "type": "jsonb",       "nullable": true },
      { "name": "model_used",               "type": "text",        "nullable": true },
      { "name": "quality_score",            "type": "numeric",     "nullable": true },
      { "name": "version",                  "type": "integer",     "nullable": true,  "default": "1" },
      { "name": "parent_workflow_id",       "type": "integer",     "nullable": true },
      { "name": "created_at",              "type": "timestamptz", "nullable": false, "default": "now()" },
      { "name": "updated_at",              "type": "timestamptz", "nullable": false, "default": "now()" }
    ],
    "foreign_keys": [
      {
        "name": "fk_workflow_parent",
        "column": "parent_workflow_id",
        "references": { "table": "PGC_Workflow", "column": "id" },
        "onDelete": "SET NULL"
      }
    ],
    "constraints": [
      {
        "type": "check",
        "name": "chk_state_strategy",
        "expression": "state_strategy IN ('fire_and_forget', 'sequential', 'sequential_with_confirmation')"
      }
    ],
    "triggers": [
      { "name": "trg_pgc_workflow_updated_at", "timing": "BEFORE UPDATE", "function": "set_updated_at()" }
    ]
  },
  {
    "table_name": "PGC_WorkflowRun",
    "target": "pgc",
    "description": "One row per workflow execution. Holds the execution stack and accumulated state.",
    "columns": [
      { "name": "id",           "type": "serial",      "primaryKey": true },
      { "name": "workflow_id",  "type": "integer",     "nullable": false },
      { "name": "status",       "type": "text",        "nullable": false, "default": "'pending'" },
      { "name": "input",        "type": "jsonb",       "nullable": true },
      { "name": "stack",        "type": "jsonb",       "nullable": false, "default": "'[]'::jsonb" },
      { "name": "output",       "type": "jsonb",       "nullable": true },
      { "name": "callback",     "type": "jsonb",       "nullable": true },
      { "name": "error",        "type": "jsonb",       "nullable": true },
      { "name": "started_at",   "type": "timestamptz", "nullable": true },
      { "name": "completed_at", "type": "timestamptz", "nullable": true },
      { "name": "created_at",   "type": "timestamptz", "nullable": false, "default": "now()" },
      { "name": "updated_at",   "type": "timestamptz", "nullable": false, "default": "now()" }
    ],
    "foreign_keys": [
      {
        "name": "fk_workflowrun_workflow",
        "column": "workflow_id",
        "references": { "table": "PGC_Workflow", "column": "id" },
        "onDelete": "RESTRICT"
      }
    ],
    "constraints": [
      {
        "type": "check",
        "name": "chk_run_status",
        "expression": "status IN ('pending', 'running', 'awaiting_confirmation', 'awaiting_human_gate', 'completed', 'failed', 'cancelled')"
      }
    ],
    "triggers": [
      { "name": "trg_pgc_workflowrun_updated_at", "timing": "BEFORE UPDATE", "function": "set_updated_at()" }
    ]
  },
  {
    "table_name": "PGC_WorkflowRunStep",
    "target": "pgc",
    "description": "Append-only audit log — one row per step execution. Never updated after insert. Used for idempotency checks on SQS redelivery and debugging.",
    "columns": [
      { "name": "id",              "type": "serial",      "primaryKey": true },
      { "name": "run_id",          "type": "integer",     "nullable": false },
      { "name": "frame_id",        "type": "text",        "nullable": false },
      { "name": "step_number",     "type": "integer",     "nullable": false },
      { "name": "step_type",       "type": "text",        "nullable": false },
      { "name": "status",          "type": "text",        "nullable": false },
      { "name": "input_snapshot",  "type": "jsonb",       "nullable": true },
      { "name": "output_snapshot", "type": "jsonb",       "nullable": true },
      { "name": "error",           "type": "jsonb",       "nullable": true },
      { "name": "duration_ms",     "type": "integer",     "nullable": true },
      { "name": "executed_at",     "type": "timestamptz", "nullable": false, "default": "now()" }
    ],
    "foreign_keys": [
      {
        "name": "fk_runstep_run",
        "column": "run_id",
        "references": { "table": "PGC_WorkflowRun", "column": "id" },
        "onDelete": "RESTRICT"
      }
    ],
    "constraints": [
      {
        "type": "check",
        "name": "chk_runstep_status",
        "expression": "status IN ('completed', 'failed', 'skipped')"
      }
    ],
    "triggers": []
  },
  {
    "table_name": "PGC_Prompt",
    "target": "pgc",
    "description": "Stores LLM prompts with versioning and quality tracking for self-improvement. Self-referential via parent_prompt_id to track prompt evolution history.",
    "columns": [
      { "name": "id",               "type": "serial",      "primaryKey": true },
      { "name": "intent_category",  "type": "text",        "nullable": false },
      { "name": "prompt_text",      "type": "text",        "nullable": false },
      { "name": "model",            "type": "text",        "nullable": true },
      { "name": "version",          "type": "integer",     "nullable": false, "default": "1" },
      { "name": "parent_prompt_id", "type": "integer",     "nullable": true },
      { "name": "was_successful",   "type": "boolean",     "nullable": true },
      { "name": "quality_score",    "type": "numeric",     "nullable": true },
      { "name": "error_log",        "type": "jsonb",       "nullable": true },
      { "name": "created_at",       "type": "timestamptz", "nullable": false, "default": "now()" },
      { "name": "updated_at",       "type": "timestamptz", "nullable": false, "default": "now()" }
    ],
    "foreign_keys": [
      {
        "name": "fk_prompt_parent",
        "column": "parent_prompt_id",
        "references": { "table": "PGC_Prompt", "column": "id" },
        "onDelete": "SET NULL"
      }
    ],
    "constraints": [],
    "triggers": [
      { "name": "trg_pgc_prompt_updated_at", "timing": "BEFORE UPDATE", "function": "set_updated_at()" }
    ]
  },
  {
    "table_name": "PGC_IntentMap",
    "target": "pgc",
    "description": "Maps user input patterns to workflows or action types for the Intent Preprocessor. workflow_id is nullable — some intents are ad-hoc and have no pre-built workflow.",
    "columns": [
      { "name": "id",              "type": "serial",      "primaryKey": true },
      { "name": "pattern",         "type": "text",        "nullable": false },
      { "name": "intent_category", "type": "text",        "nullable": false },
      { "name": "workflow_id",     "type": "integer",     "nullable": true },
      { "name": "action_type",     "type": "text",        "nullable": false },
      { "name": "created_at",      "type": "timestamptz", "nullable": false, "default": "now()" },
      { "name": "updated_at",      "type": "timestamptz", "nullable": false, "default": "now()" }
    ],
    "foreign_keys": [
      {
        "name": "fk_intentmap_workflow",
        "column": "workflow_id",
        "references": { "table": "PGC_Workflow", "column": "id" },
        "onDelete": "SET NULL"
      }
    ],
    "constraints": [
      {
        "type": "check",
        "name": "chk_action_type",
        "expression": "action_type IN ('crud', 'workflow', 'heavy_lift')"
      }
    ],
    "triggers": [
      { "name": "trg_pgc_intentmap_updated_at", "timing": "BEFORE UPDATE", "function": "set_updated_at()" }
    ]
  },
  {
    "table_name": "PGC_WorkflowRunLock",
    "target": "pgc",
    "description": "Reserved for future parallel execution — optimistic locking. NOT used in sequential mode. Bootstrapped empty.",
    "columns": [
      { "name": "id",         "type": "serial",      "primaryKey": true },
      { "name": "run_id",     "type": "integer",     "nullable": false, "unique": true },
      { "name": "locked_by",  "type": "text",        "nullable": true },
      { "name": "locked_at",  "type": "timestamptz", "nullable": true },
      { "name": "version",    "type": "integer",     "nullable": false, "default": "1" },
      { "name": "created_at", "type": "timestamptz", "nullable": false, "default": "now()" },
      { "name": "updated_at", "type": "timestamptz", "nullable": false, "default": "now()" }
    ],
    "foreign_keys": [
      {
        "name": "fk_runlock_run",
        "column": "run_id",
        "references": { "table": "PGC_WorkflowRun", "column": "id" },
        "onDelete": "CASCADE"
      }
    ],
    "constraints": [],
    "triggers": [
      { "name": "trg_pgc_workflowrunlock_updated_at", "timing": "BEFORE UPDATE", "function": "set_updated_at()" }
    ]
  }
]
