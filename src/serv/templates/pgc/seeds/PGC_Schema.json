      { "name": "allow_insert", "type": "boolean",     "nullable": false, "default": "true" },
      { "name": "allow_update", "type": "boolean",     "nullable": false, "default": "true" },
      { "name": "allow_delete", "type": "boolean",     "nullable": false, "default": "false" },
      { "name": "views",        "type": "jsonb",       "nullable": true,  "default": "'[]'::jsonb" },
      { "name": "created_at",   "type": "timestamptz", "nullable": false, "default": "now()" },
      { "name": "updated_at",   "type": "timestamptz", "nullable": false, "default": "now()" }
    ],
    "foreign_keys": [
